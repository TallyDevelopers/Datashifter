{
  "name": "org-sync-worker",
  "version": "1.0.0",
  "description": "OrgSync background worker — polls Supabase for active sync configs and executes Salesforce-to-Salesforce data syncs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
