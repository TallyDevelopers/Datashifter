# Supabase — use service role key (bypasses RLS, needed for cross-customer access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Must match TOKEN_ENCRYPTION_KEY in the main Next.js app exactly
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key

# How often to run the sync loop (milliseconds). Default: 5 minutes
WORKER_INTERVAL_MS=300000

# Secret token for the /health endpoint (set this in Railway env vars)
WORKER_SECRET=change-me-to-a-random-string

# Port for the health check HTTP server
PORT=8080
